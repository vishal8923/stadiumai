# StadiumAI Environment Variables
# Copy this file to .env and fill in the values

# Gemini AI API Key (required for AI features)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Database URL (SQLite default)
DATABASE_URL=sqlite:///./stadium_ai.db

# Security
SECRET_KEY=change-me-in-production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Environment
ENVIRONMENT=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://stadiumai-six.vercel.app

# Logging
LOG_LEVEL=INFO

# Security Headers
SECURITY_HEADERS_ENABLED=true
